# Supabase 프로젝트 설정 (Settings > API 에서 확인)
# 이 파일을 복사해 .env.local 로 저장하고 실제 값을 채우세요. .env.local은 git에 커밋되지 않습니다.

# 브라우저에서 콘텐츠를 읽어올 때 사용 (공개해도 되는 값 — RLS로 읽기 전용 보호됨)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# scripts/migrate-content-to-supabase.ts 등 로컬 마이그레이션 스크립트 전용
# service role 키는 RLS를 우회하므로 절대 공개하거나 커밋하지 마세요.
SUPABASE_SERVICE_ROLE_KEY=
