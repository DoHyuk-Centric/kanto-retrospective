# .env로 복사해서 채우세요 (git에 커밋되지 않음). Render에서는 이 값들을
# Environment 탭의 환경변수로 등록합니다.

PORT=3300

# 팀원별 4자리 PIN — JSON 문자열 하나로 관리
PINS_JSON={"박소유":"0000","김도혁":"0000","이동근":"0000","임태형":"0000"}

# scripts/seed-content.ts 로 초기 마크다운을 이관할 때만 쓰는 별도 토큰(팀원 PIN과 무관)
ADMIN_SEED_TOKEN=

# 콤마로 구분된 허용 origin 목록 (프론트엔드 배포 주소 + 로컬 개발 주소)
CORS_ORIGINS=https://dohyuk-centric.github.io,http://localhost:3000,http://localhost:3100
